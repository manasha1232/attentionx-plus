# AttentionX+ Environment Configuration
# Copy this file to .env and fill in your values

# ── Anthropic API (for caption rewriting) ─────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: Local fine-tuned model path ─────────────────────────────────────
# Leave blank to use the API fallback
LOCAL_MODEL_PATH=

# ── Whisper model size ────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large
# Larger = more accurate but slower. "base" recommended for hackathon demos.
WHISPER_MODEL=base

# ── Server settings ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
